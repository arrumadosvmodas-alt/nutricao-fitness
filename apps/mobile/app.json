{
  "expo": {
    "name": "Nutrição & Fitness",
    "slug": "nutricao-fitness",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "nutricaofitness",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f8fc"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nutricaofitness.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Permita acessar a câmera para escanear códigos de barras dos alimentos."
      }
    },
    "android": {
      "package": "com.nutricaofitness.app",
      "permissions": [
        "CAMERA"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0066ee"
      }
    },
    "plugins": [
      [
        "expo-barcode-scanner",
        {
          "cameraPermission": "Permita acessar a câmera para escanear códigos de barras dos alimentos."
        }
      ]
    ],
    "icon": "./assets/icon.png"
  }
}
