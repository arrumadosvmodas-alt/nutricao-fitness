{
  "name": "nutricao-fitness",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "android:mobile": "npm --workspace apps/mobile run android",
    "ios:mobile": "npm --workspace apps/mobile run ios",
    "web:mobile": "npm --workspace apps/mobile run web",
    "build:mobile:android": "cd apps/mobile && npx eas build -p android --profile preview",
    "build:mobile:production": "cd apps/mobile && npx eas build -p android --profile production"
  }
}
